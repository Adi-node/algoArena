generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ContestStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum PracticeStatus {
  PASSED
  ATTEMPTED
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String           @unique
  emailVerified    DateTime?
  image            String?
  leetcodeUsername    String?
  leetcodeVerifyToken String?
  createdAt           DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  accounts         Account[]
  sessions         Session[]
  solvedQuestions  UserSolved[]
  contestSessions  ContestSession[]
  upsolvingItems   UpsolvingItem[]
  weakTopicAnalyses WeakTopicAnalysis[]
  practiceAttempts  PracticeAttempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Question {
  id             String            @id @default(cuid())
  leetcodeId     Int               @unique
  slug           String            @unique
  title          String
  difficulty     Difficulty
  tags           String[]
  createdAt      DateTime          @default(now())
  solvedBy       UserSolved[]
  contestEntries ContestQuestion[]
  upsolvingItems UpsolvingItem[]
}

model UserSolved {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  solvedAt   DateTime @default(now())
  language   String?
  user       User     @relation(fields: [userId], references: [id])
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
}

model ContestSession {
  id              String            @id @default(cuid())
  userId          String
  topics          String[]
  difficulty      Difficulty?
  quantity        Int
  durationMinutes Int               @default(90)
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  status          ContestStatus     @default(ACTIVE)
  questions       ContestQuestion[]
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UpsolvingItem {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  contestTitle String
  contestDate  DateTime
  addedAt      DateTime @default(now())
  dismissed    Boolean  @default(false)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id])

  @@unique([userId, questionId])
  @@index([userId])
}

model ContestQuestion {
  id               String         @id @default(cuid())
  contestSessionId String
  questionId       String
  solved           Boolean        @default(false)
  contestSession   ContestSession @relation(fields: [contestSessionId], references: [id], onDelete: Cascade)
  question         Question       @relation(fields: [questionId], references: [id])

  @@index([contestSessionId])
}

model PracticeAttempt {
  id         String         @id @default(cuid())
  userId     String
  questionId String
  category   String
  code       String         @db.Text
  output     String         @db.Text
  status     PracticeStatus
  createdAt  DateTime       @default(now())
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model WeakTopicAnalysis {
  id         String   @id @default(cuid())
  userId     String
  createdAt  DateTime @default(now())
  topTags    String[]
  summary    String   @db.Text
  scoresJson Json
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
